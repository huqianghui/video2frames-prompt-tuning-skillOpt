# Copy to .env and fill in real values. Never commit .env.

# Azure Blob Storage holding the pre-extracted video frames.
blob4videodatasets_connection_string=
blob4videodatasets_container_name=process-videos
blob4videodatasets_videos_folder_name=training/videos
blob4videodatasets_frames_folder_name=training/frame

# Azure OpenAI resource (used for the tuned target model, the LLM judge,
# and SkillOpt's optimizer model).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Target model deployment analysed during rollouts (endpoint offers the
# gpt-4.1 and gpt-5 families).
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# LLM judge used to grade generated descriptions.
JUDGE_MODEL=gpt-4.1-mini

# Optional: send frames as base64 payloads instead of SAS URLs.
# FRAMES_AS_BASE64=1
